{
  "version": 2,
  "name": "jansahayak",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "GROQ_API_KEY": "@groq_api_key",
    "TAVILY_API_KEY": "@tavily_api_key",
    "HF_TOKEN": "@hf_token"
  }
}
